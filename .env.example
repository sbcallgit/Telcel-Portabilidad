# ============================================================
# Bot Telcel Portabilidad — Variables de entorno
# Copiar este archivo: cp .env.example .env
# Llenar los valores reales en .env (nunca commitear .env)
# ============================================================

# WhatsApp Business (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Bitrix24 (CRM)
BITRIX_WEBHOOK_URL=
BITRIX_PIPELINE_ID=

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=portabilidad
DB_USER=bot
DB_PASSWORD=botpassword

# Redis (caché y cola de mensajes)
REDIS_URL=redis://redis:6379

# Qdrant (vector database)
QDRANT_API_KEY=
QDRANT_PORT=6334

# OpenRouter (LLM gateway — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram (canal de pruebas — obtener token con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=tg_webhook_secret_dev

# Aplicación
APP_VERSION=1.0.0
ENVIRONMENT=development

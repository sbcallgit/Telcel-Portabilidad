# ============================================================
# Bot Telcel Portabilidad — Variables de entorno
# Copiar este archivo: cp .env.example .env
# Llenar los valores reales en .env (nunca commitear .env)
# ============================================================

# WhatsApp Business (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Bitrix24 — webhook REST (CRM básico)
BITRIX_WEBHOOK_URL=
BITRIX_PIPELINE_ID=

# Bitrix24 — OAuth + conector personalizado (Open Lines)
# Crear app local en: https://b24-ahyle8.bitrix24.mx → Recursos de desarrollador → Otras aplicaciones
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_CONNECTOR_ID=whatsapp_vera
BITRIX_CONNECTOR_LINE_ID=
BITRIX_STAGE_LISTO=
BITRIX_PUBLIC_URL=https://portabilidad.callcomcc.io

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=portabilidad
DB_USER=bot
# Requerido — sin default en código. docker-compose falla si está vacío.
DB_PASSWORD=

# Redis (caché y cola de mensajes)
REDIS_URL=redis://redis:6379

# Qdrant (vector database)
QDRANT_API_KEY=
QDRANT_PORT=6334

# OpenRouter (LLM gateway — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram (canal de pruebas — obtener token con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=
# Requerido para habilitar el webhook de Telegram (sin él, /webhooks/telegram queda deshabilitado)
TELEGRAM_WEBHOOK_SECRET=

# Admin — protege /admin/* y los endpoints /webhooks/telegram/setup|info
# Requerido: si está vacío, esos endpoints quedan deshabilitados (fail-closed)
ADMIN_TOKEN=
# Si se define, el job de seguimientos solo procesa ese teléfono (modo validación)
SEGUIMIENTOS_TEST_PHONE=

# Vicidial — marcador predictivo (Rescate 3). Rotar el valor expuesto previamente.
VICIDIAL_USER=api_n8n
VICIDIAL_PASS=
VICIDIAL_LIST_ID=101
VICIDIAL_CAMPAIGN_ID=n8n_port

# Caddy reverse proxy: el token del gateway RAG se setea como variable de entorno
# de Caddy (RAG_BEARER_TOKEN), NO en este archivo ni en el Caddyfile.

# Debounce de mensajes WhatsApp
# Tiempo de espera en ms antes de procesar mensajes agrupados (0 = desactivado)
DEBOUNCE_WINDOW_MS=1500

# Aplicación
APP_VERSION=1.0.0
ENVIRONMENT=development

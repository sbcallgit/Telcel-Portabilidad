# Caddyfile

# API RAG
rag-portabilidad.callcomcc.io {
    reverse_proxy api:8001

    # API Key auth simple. El token se inyecta vía variable de entorno de Caddy
    # (RAG_BEARER_TOKEN) — NUNCA hardcodear el valor aquí. Rotar el valor expuesto.
    @noauth {
        not header Authorization "Bearer {env.RAG_BEARER_TOKEN}"
        not path /health
    }
    respond @noauth 401 {
        body "Unauthorized"
        close
    }

    header {
        # CORS para n8n u otros clientes
        Access-Control-Allow-Origin "https://rag-portabilidad.callcomcc.io"
        Access-Control-Allow-Headers "Authorization, Content-Type"
        Access-Control-Allow-Methods "POST, GET, OPTIONS"
        -Server
    }

    log {
        output file /data/logs/rag.log
        format json
    }
}


# Qdrant dashboard (vector DB)
